{
  "name": "monorepo-todo-app",
  "version": "0.5.1",
  "description": "A todo app built with Bun, Hono, React, and Vite in a monorepo structure using TurboRepo.",
  "author": "Marcos Ramos",
  "license": "MIT",
  "homepage": "https://github.com/stevedylandev/bhvr",
  "packageManager": "bun@1.2.4",
  "workspaces": [
    "./server",
    "./client",
    "./shared"
  ],
  "scripts": {
    "dev": "turbo dev",
    "dev:client": "turbo dev --filter=client",
    "dev:server": "turbo dev --filter=server",
    "build": "turbo build",
    "build:client": "turbo build --filter=client",
    "build:server": "turbo build --filter=server",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "postinstall": "turbo build --filter=shared --filter=server",
    "db:generate": "cd server && drizzle-kit generate",
    "db:migrate": "cd server && drizzle-kit migrate",
    "db:push": "cd server && drizzle-kit push",
    "db:pull": "cd server && drizzle-kit pull",
    "db:studio": "cd server && drizzle-kit studio",
    "db:check": "cd server && drizzle-kit check",
    "db:drop": "cd server && drizzle-kit drop"
  },
  "keywords": [
    "bun",
    "hono",
    "react",
    "vite",
    "monorepo",
    "turbo"
  ],
  "devDependencies": {
    "bun-types": "latest",
    "turbo": "^2.6.3"
  },
  "peerDependencies": {
    "typescript": "^5.8.3"
  }
}
